{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/((?!assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/howto/:file", "destination": "/howto/:file" },
    { "source": "/(.+)", "destination": "/" }
  ]
}
